{
  "functions": {
    "source": "functions"
  },
  "hosting": {
    "site": "crossfitwebsite",
    "public": "dist",
    "ignore": [
      "firebase.json",
      "**/.*",
      "**/node_modules/**"
    ],
    "rewrites": [
      {
        "source": "/api/**",
        "function": "apiV2"
      }
    ]
  },
  "emulators": {
    "functions": {
      "host": "127.0.0.1",
      "port": 5001
    },
    "hosting": {
      "host": "127.0.0.1",
      "port": 5500
    },
    "hub": {
      "host": "127.0.0.1",
      "port": 9299
    },
    "logging": {
      "host": "127.0.0.1",
      "port": 9300
    },
    "ui": {
      "enabled": true
    },
    "singleProjectMode": true
  }
}
